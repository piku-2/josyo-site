---
import { site } from '../data/site';
const pathname = Astro.url.pathname;
const isActive = (href: string) => href === '/' ? pathname === '/' : pathname.startsWith(href);
---

<header class="site-header">
  <div class="shell header-inner">
    <a class="brand" href="/" aria-label={`${site.name} ホーム`}>
      <span class="brand-name">{site.name}</span>
      <span class="brand-sub">{site.shortName}</span>
    </a>

    <nav class="desktop-nav" aria-label="メインナビゲーション">
      {site.nav.map((item) => (
        <a href={item.href} aria-current={isActive(item.href) ? 'page' : undefined}>{item.label}</a>
      ))}
    </nav>

    <details class="mobile-nav">
      <summary aria-label="メニューを開く"><span></span><span></span><span></span></summary>
      <nav aria-label="モバイルナビゲーション">
        {site.nav.map((item) => (
          <a href={item.href} aria-current={isActive(item.href) ? 'page' : undefined}>{item.label}</a>
        ))}
      </nav>
    </details>
  </div>
</header>
