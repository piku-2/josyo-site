---
import Icon from './Icon.astro';
interface Props {
  id: string;
  name: string;
  file: string;
  icon: string;
  image?: string;
  description: string;
  activity: string;
  detailed?: boolean;
}
const { id, name, file, icon, image, description, activity, detailed = false } = Astro.props;
---

<article class:list={['team-card', { 'team-card-detailed': detailed }]} id={id}>
  {
    image ? (
      <img class="team-card-image" src={image} alt="" width={detailed ? 74 : 54} height={detailed ? 74 : 54} loading="lazy" />
    ) : (
      <Icon name={icon} size={detailed ? 66 : 42} />
    )
  }
  <div class="team-card-copy">
    <h3>{name}</h3>
    <p class="file-label">{file}</p>
    <p>{description}</p>
    <p>{activity}</p>
  </div>
  <a href={`/teams#${id}`} class="card-arrow" aria-label={`${name}を見る`}>→</a>
</article>
