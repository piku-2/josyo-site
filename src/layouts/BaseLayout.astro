---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { site } from '../data/site';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  theme?: 'home' | 'about' | 'teams' | 'works' | 'festival' | 'article';
  image?: string;
}

const {
  title,
  description = site.description,
  theme = 'home',
  image = '/images/placeholder.svg',
} = Astro.props;
const pageTitle = title ? `${title} | ${site.name}` : `${site.name} | ${site.shortName}`;
const canonical = new URL(Astro.url.pathname, Astro.site ?? Astro.url.origin);
const ogImage = new URL(image, Astro.site ?? Astro.url.origin);
---

<!doctype html>
<html lang="ja" data-theme={theme}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="ja_JP" />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <title>{pageTitle}</title>
  </head>
  <body>
    <Header />
    <main><slot /></main>
    <Footer />
  </body>
</html>
