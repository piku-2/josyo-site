---
import BaseLayout from '../layouts/BaseLayout.astro';
import AbstractGraphic from '../components/AbstractGraphic.astro';
import SectionHeading from '../components/SectionHeading.astro';
import { teams } from '../data/site';
---

<BaseLayout title="班紹介" theme="teams">
  <section class="page-hero compact-page-hero">
    <div class="shell page-hero-grid">
      <div>
        <p class="eyebrow"><span>02</span> TEAMS</p>
        <h1>班紹介</h1>
        <p class="page-intro">情報処理研究会には、5つの班があります。</p>
      </div>
      <AbstractGraphic />
    </div>
  </section>

  <section class="section shell">
    <SectionHeading number="01" label="DETAILS" title="班ごとの活動内容" />
    <div class="team-table-grid">
      {teams.map((team) => (
        <article class="team-table-card">
          <div class="team-table-heading">
            <img src={team.image} alt="" width="64" height="64" loading="lazy" />
            <div>
              <h3>{team.name}</h3>
              <p>{team.file}</p>
            </div>
          </div>
          <ul><li>{team.description}</li><li>{team.activity}</li><li>完成したものは作品ページで発表します。</li></ul>
        </article>
      ))}
    </div>
  </section>

  <section class="section shell">
    <div class="cta-strip"><p><strong>私たちの作品をもっと見る</strong><br />各班の作品を作品ページでご覧いただけます。</p><a class="button" href="/works">作品ページを見る ›</a></div>
  </section>
</BaseLayout>
