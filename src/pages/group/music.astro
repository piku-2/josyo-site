---
const sections = [
    { title: "活動内容", body: "ここに活動の説明を書く" },
    { title: "メンバー", body: "人数・募集状況など" },
    { title: "アクセス", body: "部室の場所や連絡先など" },
    { title: "班", body: "班ごとの実績や成果物など" },
];
---

<!doctype html>
<html lang="ja">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <title>情報処理研究会</title>
    </head>
    <body>
        <header>
            <h1><a href="/">情報処理研究会</a></h1>
            <p>キャッチコピーをここに</p>
        </header>

        <main>
            {
                sections.map((s) => (
                    <section>
                        <h2>{s.title}</h2>
                        <p>{s.body}</p>
                    </section>
                ))
            }
            <section>
                <a href="/group/cg">CG班のページへ</a><br />
                <a href="/group/music">音楽班のページへ</a><br />
                <a href="/group/pg">プログラミング班のページへ</a><br />
                <a href="/group/picture">イラスト班のページへ</a><br />
                <a href="/group/video">動画班のページへ</a>
            </section>
        </main>

        <footer><small>© 2026 情報処理研究会</small></footer>

        <style>
            body {
                margin: 0;
                font-family: system-ui, sans-serif;
                line-height: 1.7;
            }
            header {
                padding: 4rem 1.5rem;
                text-align: center;
                background: #1e293b;
                color: #fff;
            }
            header h1 {
                margin: 0 0 0.5rem;
                font-size: 2rem;
            }
            /* 追加：ヘッダーのリンクの見た目を整える */
            header h1 a {
                color: #fff;
                text-decoration: none;
            }
            /* お好みで：ホバー時に少し透明にするエフェクト */
            header h1 a:hover {
                opacity: 0.8;
            }
            main {
                max-width: 720px;
                margin: 0 auto;
                padding: 2rem 1.5rem;
            }
            section {
                margin-bottom: 2rem;
            }
            h2 {
                border-left: 4px solid #1e293b;
                padding-left: 0.6rem;
            }
            footer {
                text-align: center;
                padding: 2rem;
                color: #64748b;
            }
        </style>
    </body>
</html>
