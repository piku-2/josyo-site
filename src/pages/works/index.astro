---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import AbstractGraphic from '../../components/AbstractGraphic.astro';
import WorkCard from '../../components/WorkCard.astro';

const works = (await getCollection('works', ({ data }) => !data.draft))
  .sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf());
---

<BaseLayout title="作品集" theme="works">
  <section class="page-hero compact-page-hero works-hero">
    <div class="shell page-hero-grid">
      <div>
        <p class="eyebrow"><span>03</span> WORKS</p>
        <h1>作品集</h1>
        <p class="page-intro">私たちが制作したプログラム、イラスト、CG、動画、音楽の作品を紹介します。</p>
      </div>
      <AbstractGraphic />
    </div>
  </section>

  <section class="section shell works-catalog">
    <div class="filter-bar" aria-label="作品カテゴリ">
      <div class="filter-buttons">
        <button class="filter-button is-active" type="button" data-filter="all">すべて</button>
        <button class="filter-button" type="button" data-filter="programming">プログラミング</button>
        <button class="filter-button" type="button" data-filter="illustration">イラスト</button>
        <button class="filter-button" type="button" data-filter="cg">CG</button>
        <button class="filter-button" type="button" data-filter="video">動画</button>
        <button class="filter-button" type="button" data-filter="music">音楽</button>
      </div>
      <span class="sort-label" id="result-count">{works.length}件表示</span>
    </div>

    {works.length > 0 ? (
      <div class="work-grid catalog-grid" id="work-grid">
        {works.map((work) => <WorkCard work={work} />)}
      </div>
    ) : (
      <p class="empty-state">公開中の作品はまだありません。準備が整った作品から掲載します。</p>
    )}
    <p class="filter-empty" hidden>該当する作品はまだありません。</p>
  </section>

  <script>
    const buttons = Array.from(document.querySelectorAll('.filter-button'));
    const cards = Array.from(document.querySelectorAll('#work-grid .work-card'));
    const empty = document.querySelector('.filter-empty');
    const resultCount = document.querySelector('#result-count');

    buttons.forEach((button) => {
      button.addEventListener('click', () => {
        const filter = button.getAttribute('data-filter');
        buttons.forEach((item) => item.classList.toggle('is-active', item === button));
        let visibleCount = 0;
        cards.forEach((card) => {
          const teams = card.getAttribute('data-teams')?.split(' ') ?? [];
          const show = filter === 'all' || teams.includes(filter);
          card.toggleAttribute('hidden', !show);
          if (show) visibleCount += 1;
        });
        if (empty) empty.toggleAttribute('hidden', visibleCount > 0 || filter === 'all');
        if (resultCount) resultCount.textContent = `${visibleCount}件表示`;
      });
    });
  </script>
</BaseLayout>
