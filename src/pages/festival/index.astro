---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SectionHeading from "../../components/SectionHeading.astro";
import Icon from "../../components/Icon.astro";
import { festival } from "../../data/site";
---

<BaseLayout title="文化祭" theme="festival">
  <section class="festival-page-hero shell">
    <p class="eyebrow"><span>04</span> FESTIVAL</p>
    <h1>文化祭 <small>{festival.year}</small></h1>
    <div class="festival-hero-card">
      <div class="festival-illustration" aria-hidden="true">
        <span class="festival-building"></span>
        <span class="festival-tent"></span>
        <span class="festival-flags"></span>
        <span class="festival-sparkles"></span>
      </div>
      <div class="festival-hero-copy">
        <h2>つくる、試す、公開する。</h2>
        <p>
          文化祭の開催日、会場、来場時の案内をこのページでお知らせします。作品の紹介は作品ページにまとめて掲載します。
        </p>
        <dl>
          <div>
            <dt><Icon name="calendar" size={24} />開催日</dt><dd>
              {festival.date}
            </dd>
          </div>
          <div>
            <dt><Icon name="pin" size={24} />場所</dt><dd>{festival.place}</dd>
          </div>
          <div>
            <dt><Icon name="clock" size={24} />開催時間</dt><dd>
              {festival.time}
            </dd>
          </div>
        </dl>
      </div>
    </div>
  </section>

  <section class="section shell">
    <SectionHeading number="05" label="ACCESS" title="アクセス・案内" />
    <div class="access-grid">
      <article>
        <Icon name="train" /><h3>アクセス</h3><p>
          JR中央線「国分寺駅」北口より<br />徒歩約10分。
        </p>
      </article>
      <article>
        <Icon name="clock" /><h3>開催時間</h3><p>{festival.time}</p>
      </article>
      <article><Icon name="map" /><h3>会場</h3><p>{festival.place}</p></article>
      <article>
        <Icon name="alert" /><h3>お願い</h3><p>{festival.notice}</p>
      </article>
    </div>
  </section>

  <section class="section shell">
    <div class="cta-strip">
      <p><strong>作品紹介は作品ページへ</strong><br />文化祭以外の作品も、作品ページにまとめて掲載します。</p>
      <a class="button" href="/works">作品ページを見る ›</a>
    </div>
  </section>
</BaseLayout>
